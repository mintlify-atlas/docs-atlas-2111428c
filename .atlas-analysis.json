  "keyFeatures": [
    "Secure link generation with short codes",
    "File upload and sharing",
    "URL shortening",
    "Access control (expiration, max views, password protection)",
    "Comprehensive audit logging",
    "Real-time metrics and statistics",
    "Health checks and Prometheus integration"
  ],
  "publicApiSurface": [
    "POST /api/links - Create secure link for URL",
    "POST /api/links/upload - Upload file and create link",
    "GET /l/{shortCode} - Resolve and access link",
    "DELETE /l/{shortCode} - Revoke link",
    "GET /api/stats/access/summary - Access statistics summary",
    "GET /api/stats/access/hourly - Hourly access distribution",
    "GET /api/stats/access/daily - Daily access counts",
    "GET /api/stats/access/failures - Access failure breakdown",
    "GET /api/stats/links - Link status statistics",
    "GET /api/stats/links/top - Most accessed links",
    "GET /api/stats/security/exceptions - Security exception tracking",
    "GET /actuator/health - Health check endpoint",
    "GET /actuator/prometheus - Prometheus metrics"
  ]
